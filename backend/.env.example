# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=civic_app_db
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d

# OTP Configuration (Mock)
OTP_LENGTH=6
OTP_EXPIRY=5

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Google Maps API (Mock if not provided)
GOOGLE_MAPS_API_KEY=mock_api_key

# Firebase (Mock)
FIREBASE_PROJECT_ID=mock_project
FIREBASE_PRIVATE_KEY=mock_key
FIREBASE_CLIENT_EMAIL=mock@firebase.com

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
